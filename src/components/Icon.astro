const { name, class: className, size = 'md', strokeWidth = 2 } = Astro.props;

const paths = ICONS[name];

if (!paths && import.meta.env.DEV) {
  console.warn(`[Icon] Unknown icon: "${name}"`);
}

const SIZE_CLASSES: Record<string, string> = {
  sm: 'w-4 h-4',
  md: 'w-6 h-6',
  lg: 'w-8 h-8',
  xl: 'w-12 h-12',
};
---

{paths && (
  <svg
    class:list={[className || SIZE_CLASSES[size]]}
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    {paths.map((d) => (
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width={strokeWidth} d={d} />
    ))}
  </svg>
)}
