---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Contact & Accès"
  description="Contactez l'Espace Satya à Elne — 17 bd des Évadés de France, 1er étage Épicentre, 66200 Elne. Parking gratuit, 15 min de Perpignan."
>
  <Header />
  <main>

    <!-- Header de page -->
    <section class="bg-gradient-to-br from-sage-100 to-warm-100 py-16 md:py-20 px-4 md:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <p class="font-accent text-sage-600 text-xl mb-3">Nous trouver</p>
        <h1 class="font-heading text-5xl md:text-6xl font-light text-warm-900 mb-5">Contact & Accès</h1>
        <p class="font-body text-warm-600 text-lg max-w-xl mx-auto leading-relaxed">
          Venez nous rendre visite à Elne, ou écrivez-nous pour toute question sur nos praticien·ne·s ou la Salle B3.
        </p>
      </div>
    </section>

    <!-- Contenu principal : infos + formulaire -->
    <section class="py-16 md:py-20 px-4 md:px-8 bg-warm-50">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

          <!-- Colonne gauche : infos pratiques -->
          <div>
            <h2 class="font-heading text-3xl font-light text-warm-900 mb-8">Informations pratiques</h2>

            <!-- Adresse -->
            <div class="mb-8 flex items-start gap-4">
              <div class="w-12 h-12 bg-sage-100 rounded-full flex items-center justify-center shrink-0 mt-1">
                <svg class="w-6 h-6 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-lg font-semibold text-warm-900 mb-1">Adresse</h3>
                <address class="not-italic font-body text-warm-600 leading-relaxed">
                  17 boulevard des Évadés de France<br />
                  1er étage — Centre commercial Épicentre<br />
                  66200 Elne<br />
                  Pyrénées-Orientales (Occitanie)
                </address>
                <a
                  href="https://maps.google.com/?q=17+boulevard+des+Évadés+de+France+Elne+66200"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 mt-3 font-body text-sm font-medium text-sage-600 hover:text-sage-700 transition-colors"
                >
                  Ouvrir dans Google Maps
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
            </div>

            <!-- Email -->
            <div class="mb-8 flex items-start gap-4">
              <div class="w-12 h-12 bg-sage-100 rounded-full flex items-center justify-center shrink-0 mt-1">
                <svg class="w-6 h-6 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-lg font-semibold text-warm-900 mb-1">Email</h3>
                <a href="mailto:contact@espacesatya.fr" class="font-body text-warm-600 hover:text-sage-600 transition-colors">
                  contact@espacesatya.fr
                </a>
              </div>
            </div>

            <!-- Horaires -->
            <div class="mb-8 flex items-start gap-4">
              <div class="w-12 h-12 bg-sage-100 rounded-full flex items-center justify-center shrink-0 mt-1">
                <svg class="w-6 h-6 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-lg font-semibold text-warm-900 mb-2">Horaires d'ouverture</h3>
                <dl class="font-body text-warm-600 space-y-1.5">
                  {[
                    { j: 'Lundi — Vendredi', h: '9h00 – 19h00' },
                    { j: 'Samedi', h: '9h00 – 17h00' },
                    { j: 'Dimanche', h: 'Fermé (sur rendez-vous)' },
                  ].map((slot) => (
                    <div class="flex gap-2">
                      <dt class="font-medium text-warm-700 min-w-[160px]">{slot.j}</dt>
                      <dd>{slot.h}</dd>
                    </div>
                  ))}
                </dl>
                <p class="font-body text-xs text-warm-400 mt-2">Les horaires varient selon les praticiennes. Consultez directement la praticienne souhaitée.</p>
              </div>
            </div>

            <!-- Accès -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-sage-100 rounded-full flex items-center justify-center shrink-0 mt-1">
                <svg class="w-6 h-6 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading text-lg font-semibold text-warm-900 mb-2">Comment venir</h3>
                <ul class="font-body text-warm-600 space-y-2">
                  <li class="flex items-center gap-2">
                    <span class="text-sm">🚗</span>
                    <span><strong class="text-warm-800">En voiture</strong> — Parking gratuit du centre Épicentre, entrée principale</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-sm">🚉</span>
                    <span><strong class="text-warm-800">En train</strong> — Gare d'Elne à 10 min à pied</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-sm">📍</span>
                    <span><strong class="text-warm-800">Depuis Perpignan</strong> — 15 min (D900)</span>
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="text-sm">🌊</span>
                    <span><strong class="text-warm-800">Depuis la côte</strong> — 10 min depuis Argelès-sur-Mer</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Colonne droite : formulaire -->
          <div>
            <h2 class="font-heading text-3xl font-light text-warm-900 mb-8">Nous écrire</h2>
            <form
              class="space-y-5"
              name="contact"
              method="POST"
              novalidate
            >
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="nom" class="block font-body text-sm font-semibold text-warm-700 mb-1.5">Nom complet *</label>
                  <input type="text" id="nom" name="nom" required autocomplete="name"
                    class="w-full px-4 py-3 rounded-xl bg-white border border-warm-200 font-body text-warm-800 placeholder:text-warm-300 focus:outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-100 transition-all"
                    placeholder="Votre nom" />
                </div>
                <div>
                  <label for="email" class="block font-body text-sm font-semibold text-warm-700 mb-1.5">Email *</label>
                  <input type="email" id="email" name="email" required autocomplete="email"
                    class="w-full px-4 py-3 rounded-xl bg-white border border-warm-200 font-body text-warm-800 placeholder:text-warm-300 focus:outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-100 transition-all"
                    placeholder="votre@email.fr" />
                </div>
              </div>

              <div>
                <label for="telephone" class="block font-body text-sm font-semibold text-warm-700 mb-1.5">Téléphone</label>
                <input type="tel" id="telephone" name="telephone" autocomplete="tel"
                  class="w-full px-4 py-3 rounded-xl bg-white border border-warm-200 font-body text-warm-800 placeholder:text-warm-300 focus:outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-100 transition-all"
                  placeholder="06 XX XX XX XX" />
              </div>

              <div>
                <label for="sujet" class="block font-body text-sm font-semibold text-warm-700 mb-1.5">Sujet *</label>
                <select id="sujet" name="sujet" required
                  class="w-full px-4 py-3 rounded-xl bg-white border border-warm-200 font-body text-warm-800 focus:outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-100 transition-all">
                  <option value="">Sélectionner un sujet...</option>
                  <option value="praticien">Question sur une praticienne</option>
                  <option value="salle">Location de la Salle B3</option>
                  <option value="rdv">Prendre rendez-vous</option>
                  <option value="autre">Autre</option>
                </select>
              </div>

              <div>
                <label for="message" class="block font-body text-sm font-semibold text-warm-700 mb-1.5">Message *</label>
                <textarea id="message" name="message" rows={5} required
                  class="w-full px-4 py-3 rounded-xl bg-white border border-warm-200 font-body text-warm-800 placeholder:text-warm-300 focus:outline-none focus:border-sage-400 focus:ring-2 focus:ring-sage-100 transition-all resize-y"
                  placeholder="Comment pouvons-nous vous aider ?"></textarea>
              </div>

              <button type="submit"
                class="w-full bg-sage-500 text-white font-body font-semibold py-4 rounded-full hover:bg-sage-600 transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5">
                Envoyer le message
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- Carte Google Maps -->
    <section class="bg-warm-100" aria-label="Plan d'accès Espace Satya Elne">
      <iframe
        title="Localisation Espace Satya — Elne"
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2892.5!2d2.9745!3d42.5997!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12b07b3e9b3c3b7d%3A0x0!2s17+Boulevard+des+%C3%89vad%C3%A9s+de+France%2C+66200+Elne!5e0!3m2!1sfr!2sfr!4v1700000000000"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen={true}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="block"
      ></iframe>
    </section>

  </main>
  <Footer />
</BaseLayout>
